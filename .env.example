PORT=5000
NODE_ENV=development
# If Google login fails with "unable to verify the first certificate" (common on Windows
# behind antivirus/SSL inspection), the npm scripts use Node's --use-system-ca (Node 22+).
DATABASE_URL=mongodb://localhost:27017/servecare
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Chat AI: Groq (used first). Multiple keys = automatic failover on rate limits.
# Option A — single key (legacy):
GROQ_API_KEY=
# Option B — several keys (comma or newline). First key below is still used if you also set GROQ_API_KEY (deduped).
GROQ_API_KEYS=
# Optional fallback when all Groq keys fail:
GEMINI_API_KEY=

# Razorpay (online booking payments) — https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Password reset emails (nodemailer). Required in production.
# Example Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Optional; defaults to SMTP_USER
EMAIL_FROM=